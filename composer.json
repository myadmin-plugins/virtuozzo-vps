{
	"name": "detain/myadmin-virtuozzo-vps",
	"type": "myadmin-plugin",
	"description": "MyAdmin Virtuozzo VPS plugin — provides event-driven provisioning, deactivation, and queue management for Virtuozzo-based virtual private servers within the MyAdmin ecosystem.",
	"keywords": [
		"virtuozzo",
		"vps",
		"myadmin",
		"plugin",
		"provisioning",
		"virtualization",
		"administration"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminVirtuozzo\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminVirtuozzo\\Tests\\": "tests/"
		}
	}
}
